        {
            "parameters": {
                "jsCode": "const fs = require('fs');\nconst path = require('path');\n\n// Percorso configurato nel tuo docker-compose\nconst basePath = \"/home/node/codebase\";\n\n\n// Cartelle da escludere\nconst excludeDirs = ['.git', 'node_modules', 'venv', '__pycache__'];\n\nconst fileList = [];\n\n/**\n * Funzione ricorsiva per scansionare le directory\n */\nfunction walkSync(currentPath) {\n    const items = fs.readdirSync(currentPath);\n\n    for (const item of items) {\n        const fullPath = path.join(currentPath, item);\n        const stat = fs.statSync(fullPath);\n\n        if (stat.isDirectory()) {\n            // Se è una directory e non è tra quelle escluse, entra ricorsivamente\n            if (!excludeDirs.includes(item)) {\n                walkSync(fullPath);\n            }\n        } else {\n            fileList.push({path: fullPath, name: item});\n            \n        }\n    }\n}\n\n// Avvia la scansione\ntry {\n    walkSync(basePath);\n} catch (error) {\n    // Gestione errore nel caso la cartella non esista o manchino i permessi\n    return [{ error: error }];\n}\n\nreturn fileList;"
            },
