            "parameters": {
                "jsCode": "const fs = require('fs');\n\n// Prendi il path dal nodo precedente (il loop)\nconst filePath = $input.first().json.path;\n\ntry {\n  // Legge il file come buffer\n  const fileBuffer = fs.readFileSync(filePath);\n  \n  // Ritorna il contenuto come dato binario che n8n può processare\n  return {\n    json: {\n      file_name: $input.first().json.name,\n      file_path: filePath\n    },\n    binary: {\n      data: { // Questa deve chiamarsi 'data'\n        data: fileBuffer.toString('base64'),\n        fileName: $input.first().json.name,\n        fileExtension: filePath.split('.').pop(),\n        mimeType: 'text/plain' // Aiuta il Data Loader a capire che è testo\n      }\n    }\n  };\n} catch (error) {\n  return { json: { error: error, path: filePath } };\n}"
            },
